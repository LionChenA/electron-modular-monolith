{
  "name": "electron-modular-monolith",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "check": "biome check --write",
    "check:unsafe": "biome check --write --unsafe",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "generate": "tsr generate",
    "depcruise": "depcruise src --config .dependency-cruiser.js",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:main": "vitest --project main",
    "test:renderer": "vitest --project renderer",
    "test:component": "vitest --project storybook",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "kubb": "kubb generate --config kubb.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@orama/orama": "^3.1.18",
    "@orpc/react": "^1.13.2",
    "@orpc/tanstack-query": "^1.13.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-router": "^1.147.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.562.0",
    "shadcn": "^3.6.3",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fission-ai/openspec": "^1.2.0",
    "@kubb/cli": "^4.37.0",
    "@kubb/core": "^4.37.0",
    "@kubb/plugin-faker": "^4.37.0",
    "@kubb/plugin-msw": "^4.37.0",
    "@kubb/plugin-oas": "^4.37.0",
    "@kubb/plugin-ts": "^4.37.0",
    "@kubb/plugin-zod": "^4.37.0",
    "@orpc/client": "^1.13.13",
    "@orpc/contract": "^1.13.6",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@tanstack/router-plugin": "^1.149.0",
    "@tanstack/virtual-file-routes": "^1.145.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dependency-cruiser": "^17.3.6",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.10",
    "node-fetch": "^2.7.0",
    "node-gyp": "^12.2.0",
    "openspec": "^0.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "storybook": "^10.2.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "vite": "npm:rolldown-vite@latest"
    },
    "ignoredBuiltDependencies": [
      "@fission-ai/openspec",
      "better-sqlite3"
    ]
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
